<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <ImageView
            android:id="@+id/imgPet"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/bg_pet_image"
            android:contentDescription="@null"
            android:padding="6dp"
            android:scaleType="centerCrop"
            android:src="@drawable/imagen_gatito"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtPetName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:textColor="@color/adoptame_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/imgPet"
            app:layout_constraintTop_toTopOf="@id/imgPet" />

        <TextView
            android:id="@+id/txtPetType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/adoptame_orange"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/txtPetName"
            app:layout_constraintTop_toBottomOf="@id/txtPetName" />

        <TextView
            android:id="@+id/txtPetBreed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/adoptame_text_secondary"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/txtPetName"
            app:layout_constraintTop_toBottomOf="@id/txtPetType" />

        <TextView
            android:id="@+id/txtPetSex"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/adoptame_text_secondary"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/txtPetName"
            app:layout_constraintTop_toBottomOf="@id/txtPetBreed" />

        <TextView
            android:id="@+id/txtPetStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/adoptame_text_secondary"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@id/txtPetBadge"
            app:layout_constraintStart_toStartOf="@id/txtPetName"
            app:layout_constraintTop_toBottomOf="@id/txtPetSex" />

        <TextView
            android:id="@+id/txtPetBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_badge"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:text="@string/pet_status_adoption"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtPetSex" />

        <Button
            android:id="@+id/btnAdopt"
            style="@style/AuthPrimaryButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:minHeight="40dp"
            android:text="@string/btn_request_adoption"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/txtPetName"
            app:layout_constraintTop_toBottomOf="@id/txtPetBadge" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
